rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── B2B result PDFs ───────────────────────────────────────────────────────
    // Protected path: results/b2b/{organizationId}/{batchId}/{sampleId}.pdf
    // NO public read — access only via Cloud Function signed URLs
    match /results/b2b/{organizationId}/{batchId}/{filename} {
      allow read: if false;   // Signed URLs generated server-side only
      allow write: if
        request.auth != null
        && request.auth.token.role in ['admin', 'staff', 'doctor']
        && request.resource.contentType == 'application/pdf'
        && request.resource.size < 50 * 1024 * 1024; // 50MB max
    }

    // ─── B2C result PDFs ──────────────────────────────────────────────────────
    match /results/b2c/{customerId}/{filename} {
      allow read: if false;   // Signed URLs only
      allow write: if
        request.auth != null
        && request.auth.token.role in ['admin', 'staff', 'doctor']
        && request.resource.contentType == 'application/pdf'
        && request.resource.size < 50 * 1024 * 1024;
    }

    // ─── Public assets ────────────────────────────────────────────────────────
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }

    // ─── Deny everything else ─────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
